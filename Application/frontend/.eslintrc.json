{
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "react/no-unescaped-entities": "off",
    "react/no-children-prop": "off"
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
